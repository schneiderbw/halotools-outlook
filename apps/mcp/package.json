{
  "name": "halo-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing HaloPSA as tools for AI assistants (Claude Desktop, ChatGPT desktop, Cursor, etc.).",
  "type": "module",
  "bin": {
    "halo-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@iusehalo/halo-api": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3"
  }
}
