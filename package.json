{
  "name": "halo-outlook-addin",
  "version": "0.1.0",
  "private": true,
  "description": "Outlook task-pane add-in for HaloPSA — sender lookup, ticket context, log-to-ticket. Multi-tenant SPA at tools.iusehalo.com.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "validate-manifest": "npx office-addin-manifest validate public/manifest.json"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "fflate": "^0.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.430",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "office-addin-manifest": "^1.13.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
