{
  "name": "@iusehalo/halo-api",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic HaloPSA client: fetch wrapper, OAuth2+PKCE, RFC Message-ID ticket threading. Pure logic, no React, no Fluent, no Office.js.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --build --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
